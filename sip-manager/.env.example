APP_NAME="SIP Manager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=sip_manager
DB_USERNAME=sip
DB_PASSWORD=

# Asterisk Realtime Database
DB_AST_HOST=db
DB_AST_PORT=3306
DB_AST_DATABASE=asterisk_rt
DB_AST_USERNAME=sip
DB_AST_PASSWORD=

# Asterisk AMI
ASTERISK_AMI_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=laravel_ami
ASTERISK_AMI_SECRET=

# SIP defaults
SIP_DEFAULT_CONTEXT=from-internal
SIP_DEFAULT_TRANSPORT=transport-udp
SIP_DEFAULT_CODECS=alaw,ulaw,g722

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
