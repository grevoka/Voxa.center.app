# ── App ──
APP_NAME="SIP Manager"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=80
APP_SSL_PORT=443

# ── MariaDB ──
DB_ROOT_PASSWORD=wawa2346
DB_APP_DATABASE=sip_manager
DB_APP_USERNAME=sip_admin
DB_APP_PASSWORD=sip_app_secret
DB_AST_DATABASE=asterisk_rt
DB_AST_USERNAME=asterisk_user
DB_AST_PASSWORD=ast_secret
DB_EXTERNAL_PORT=3307

# ── Redis ──
REDIS_PASSWORD=redis_secret
REDIS_EXTERNAL_PORT=6380

# ── Asterisk ──
AMI_USER=laravel_ami
AMI_PASSWORD=ami_secret
# Laisser vide pour auto-detection via api.ipify.org
PUBLIC_IP=
LOCAL_NET=127.0.0.0/8
RTP_START=10000
RTP_END=10100
